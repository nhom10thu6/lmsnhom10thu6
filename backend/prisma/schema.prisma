generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model test {
  id    Int     @id @default(autoincrement())
  name  String?
  email String?
  phone Int?
}

model khoahoc {
  idKhoaHoc   Int       @id @default(autoincrement())
  tenKhoaHoc  String
  moTa        String?
  danhMuc     String?
  idGiangVien Int?
  gia         Decimal?  @default(0.00)
  ngayTao     DateTime? @default(now())

  baihoc            baihoc[]
  certificates      certificates[]
  dangky_khoahoc    dangky_khoahoc[]
  instructor_payout instructor_payout[]
  progress          progress[]
  quizzes            quizzes[]

  nguoidung nguoidung? @relation(fields: [idGiangVien], references: [idNguoiDung])

  @@index([idGiangVien])
}

model nguoidung {
  idNguoiDung Int    @id @default(autoincrement())
  hoTen        String
  taiKhoan     String @unique
  
  // 1. SỬA: Thêm dấu ? để mật khẩu có thể trống khi dùng Google
  matKhau      String? 
  
  vaiTro       nguoidung_vaiTro? @default(hocvien)

  // 2. THÊM: Lưu ID định danh từ Google để nhận diện người dùng
  googleId     String? @unique

  // --- CÁC QUAN HỆ CŨ GIỮ NGUYÊN 100% ---
  certificates      certificates[]
  dangky_khoahoc    dangky_khoahoc[]
  instructor_payout instructor_payout[]
  khoahoc           khoahoc[]
  progress          progress[]
  quiz_results      quiz_results[]
}

model baihoc {
  idBaiHoc   Int    @id @default(autoincrement())
  idKhoaHoc  Int
  tenBaiHoc  String
  videoUrl   String?
  taiLieuUrl String?
  thuTu      Int?

  khoahoc  khoahoc @relation(fields: [idKhoaHoc], references: [idKhoaHoc], onDelete: Cascade)
  progress progress[]

  @@index([idKhoaHoc])
}

model certificates {
  idCertificate Int       @id @default(autoincrement())
  idNguoiDung   Int
  idKhoaHoc     Int?
  ngayCap       DateTime? @default(now())

  khoahoc  khoahoc?  @relation(fields: [idKhoaHoc], references: [idKhoaHoc])
  nguoidung nguoidung @relation(fields: [idNguoiDung], references: [idNguoiDung])

  @@index([idNguoiDung])
  @@index([idKhoaHoc])
}

model instructor_payout {
  idPayout    Int       @id @default(autoincrement())
  idGiangVien Int
  idKhoaHoc   Int
  soTien      Decimal?
  trangThai   instructor_payout_trangThai? @default(cho_thanh_toan)
  ngayTao     DateTime? @default(now())

  nguoidung nguoidung @relation(fields: [idGiangVien], references: [idNguoiDung])
  khoahoc   khoahoc   @relation(fields: [idKhoaHoc], references: [idKhoaHoc])

  @@index([idGiangVien])
  @@index([idKhoaHoc])
}

model progress {
  idProgress  Int    @id @default(autoincrement())
  idNguoiDung Int
  idKhoaHoc   Int
  idBaiHoc    Int
  trangThai   progress_trangThai? @default(chua_hoc)
  thoiGianHoc Int? @default(0)

  baihoc    baihoc    @relation(fields: [idBaiHoc], references: [idBaiHoc], onDelete: Cascade)
  khoahoc   khoahoc   @relation(fields: [idKhoaHoc], references: [idKhoaHoc], onDelete: Cascade)
  nguoidung nguoidung @relation(fields: [idNguoiDung], references: [idNguoiDung], onDelete: Cascade)

  @@index([idNguoiDung])
  @@index([idKhoaHoc])
  @@index([idBaiHoc])
}

model quizzes {
  idQuiz         Int    @id @default(autoincrement())
  idKhoaHoc      Int
  tenQuiz        String
  thoiGianLamBai Int?

  khoahoc        khoahoc          @relation(fields: [idKhoaHoc], references: [idKhoaHoc], onDelete: Cascade)
  quiz_questions quiz_questions[]
  quiz_results   quiz_results[]

  @@index([idKhoaHoc])
}

model quiz_questions {
  idCauHoi   Int     @id @default(autoincrement())
  idQuiz     Int
  cauHoi     String
  dapAnDung  String?
  diemCauHoi Decimal? @default(1.00)

  // --- Trac Ngiem ---
  loaiCauHoi  String?  @default("tracnghiem")
  dapAnA      String?  
  dapAnB      String?  
  dapAnC      String?  
  dapAnD      String?  
  // ----------------------------------------------

  quizzes quizzes @relation(fields: [idQuiz], references: [idQuiz], onDelete: Cascade)

  @@index([idQuiz])
}

model quiz_results {
  idKetQua       Int       @id @default(autoincrement())
  idNguoiDung    Int
  idQuiz         Int?
  diemSo         Decimal?
  thoiGianLamBai Int?
  ngayLamBai     DateTime? @default(now())

  nguoidung nguoidung @relation(fields: [idNguoiDung], references: [idNguoiDung], onDelete: Cascade)
  quizzes   quizzes?  @relation(fields: [idQuiz], references: [idQuiz])

  @@index([idNguoiDung])
  @@index([idQuiz])
}

model dangky_khoahoc {
  idDangKy       Int       @id @default(autoincrement())
  idNguoiDung    Int
  idKhoaHoc      Int
  ngayDangKy     DateTime? @default(now())
  /// Khóa miễn phí: ghi nhận ngay khi đăng ký. Khóa trả phí: null cho đến khi thanh toán xong.
  ngayThanhToan  DateTime?

  nguoidung nguoidung @relation(fields: [idNguoiDung], references: [idNguoiDung])
  khoahoc   khoahoc   @relation(fields: [idKhoaHoc], references: [idKhoaHoc])

  @@unique([idNguoiDung, idKhoaHoc])
}

enum nguoidung_vaiTro {
  hocvien
  giangvien
  admin
}

enum instructor_payout_trangThai {
  cho_thanh_toan
  da_thanh_toan
}

enum progress_trangThai {
  chua_hoc
  dang_hoc
  hoan_thanh
}